# Copy this file to application.properties and fill in your MySQL password.

churn.api.base-url=http://localhost:8000

spring.datasource.url=jdbc:mysql://localhost:3306/churnpredictor
spring.datasource.username=churnpredictor
spring.datasource.password=CHANGE_ME

# schema is owned by churnpredictor-setup.sql, Hibernate must not touch it
spring.jpa.hibernate.ddl-auto=none

# default is 1MB; the Kaggle CSV alone is ~0.95MB
spring.servlet.multipart.max-file-size=20MB
spring.servlet.multipart.max-request-size=20MB
